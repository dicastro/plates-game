{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "gitRawCommitsOpts": {
        "path": [
          ".",
          "../shared"
        ]
      }
    }
  },
  "git": {
    "commitMessage": "chore(back): release v${version}",
    "tagName": "back-v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": [
      "npm run typecheck"
    ]
  }
}