{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "gitRawCommitsOpts": {
        "path": [
          "src",
          "shared",
          "public",
          "index.html"
        ]
      }
    }
  },
  "git": {
    "commitMessage": "chore(front): release v${version}",
    "tagName": "front-v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": [
      "npm run build"
    ]
  }
}