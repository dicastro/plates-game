{
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md",
      "gitRawCommitsOpts": {
        "args": ["--", ".", ":(exclude)worker"]
      }
    }
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": [
      "npm run build"
    ]
  }
}